# ─── Application ───────────────────────────────
NODE_ENV=development
PORT=3002

# ─── Database ──────────────────────────────────
DATABASE_URL="postgresql://schedule_user:schedule_password@localhost:5434/schedule_db"

# ─── Auth Service ──────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001/graphql

# ─── Redis ─────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Email (template – configure SMTP to activate) ──────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=no-reply@example.com
MAIL_PASS=changeme
MAIL_FROM="Healthcare System <no-reply@example.com>"
